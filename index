<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <base target="_top">
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    :root {
      --font: 'IBM Plex Sans Arabic', system-ui, sans-serif;
      --accent:       #e53e3e;
      --accent-dark:  #c53030;
      --accent-alpha: rgba(229,62,62,.13);
      --green:        #16a34a;
      --green-bg:     #f0fdf4;
      --green-border: #bbf7d0;
      --green-badge:  #dcfce7;
      --green-text:   #15803d;
      --red:          #dc2626;
      --red-bg:       #fff5f5;
      --red-border:   #fecaca;
      --red-badge:    #fee2e2;
      --red-text:     #b91c1c;
      --bg:           #f4f6f9;
      --surface:      #ffffff;
      --surface-2:    #f8fafc;
      --border:       rgba(0,0,0,.07);
      --border-med:   rgba(0,0,0,.11);
      --text-1:       #111827;
      --text-2:       #6b7280;
      --text-3:       #9ca3af;
      --shadow-sm:    0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
      --shadow-md:    0 4px 14px rgba(0,0,0,.08);
      --r-sm: 8px; --r-md: 12px; --r-lg: 16px;
    }

    [data-theme="dark"] {
      --accent:       #fc8181;
      --accent-dark:  #f56565;
      --accent-alpha: rgba(252,129,129,.15);
      --green:        #4ade80;
      --green-bg:     rgba(20,83,45,.3);
      --green-border: rgba(20,83,45,.55);
      --green-badge:  rgba(20,83,45,.4);
      --green-text:   #86efac;
      --red:          #f87171;
      --red-bg:       rgba(127,29,29,.3);
      --red-border:   rgba(127,29,29,.55);
      --red-badge:    rgba(127,29,29,.4);
      --red-text:     #fca5a5;
      --bg:           #0d1117;
      --surface:      #161b22;
      --surface-2:    #1e2530;
      --border:       rgba(255,255,255,.06);
      --border-med:   rgba(255,255,255,.10);
      --text-1:       #e6edf3;
      --text-2:       #8b949e;
      --text-3:       #484f58;
      --shadow-sm:    0 1px 3px rgba(0,0,0,.25);
      --shadow-md:    0 4px 14px rgba(0,0,0,.35);
    }

    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{height:100%}

    body{
      font-family:var(--font);
      background:var(--bg);
      color:var(--text-1);
      min-height:100%;
      padding-bottom:130px;
      transition:background .25s,color .25s;
      -webkit-tap-highlight-color:transparent;
      touch-action:manipulation;
      -webkit-font-smoothing:antialiased;
      font-size:16px;
      line-height:1.5;
    }

    /* ══════════════════════════════════════
       HEADER – Responsive two-row layout
       ══════════════════════════════════════ */
    .hdr{
      position:sticky;top:0;z-index:100;
      background:var(--surface);
      border-bottom:1px solid var(--border);
      padding:0 22px;
    }

    .hdr-row{
      display:flex;align-items:center;
      justify-content:space-between;
      height:64px;gap:10px;
    }

    /* On small screens, allow header to grow and wrap */
    @media(max-width:640px){
      .hdr{padding:0 14px}
      .hdr-row{height:auto;flex-wrap:wrap;padding:10px 0;gap:8px}
    }

    .logo{display:flex;align-items:center;gap:11px;flex-shrink:0}

    .logo-mark{
      width:38px;height:38px;
      background:var(--accent);
      border-radius:var(--r-sm);
      display:flex;align-items:center;justify-content:center;
      font-size:18px;font-weight:700;color:#fff;
    }

    .logo-name{font-size:17px;font-weight:700;color:var(--text-1)}

    /* Right side of header: groups controls */
    .hdr-right{display:flex;align-items:center;gap:9px;flex-shrink:0}

    /* On very small screens, controls wrap to a second row */
    @media(max-width:640px){
      .hdr-right{
        width:100%;
        flex-wrap:wrap;
        justify-content:flex-end;
        gap:7px;
      }
    }

    /* shared control style */
    .ctrl{
      height:40px;
      background:var(--surface-2);
      border:1px solid var(--border-med);
      border-radius:var(--r-sm);
      font-family:var(--font);
      font-size:14px;font-weight:500;
      color:var(--text-1);
      padding:0 12px;
      outline:none;
      transition:border-color .18s,box-shadow .18s;
      cursor:pointer;
      appearance:none;-webkit-appearance:none;
    }
    .ctrl:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-alpha)}

    /* Date picker wrapper with "today" indicator */
    .date-wrap{position:relative;display:flex;align-items:center;}

    input[type="date"].ctrl{
      min-width:140px;
      padding-left:10px;
    }

    /* Flashing "اليوم" badge shown when selected date = today */
    .today-badge{
      position:absolute;
      left:-2px;
      top:50%;transform:translateY(-50%);
      background:var(--accent);
      color:#fff;
      font-size:10px;font-weight:700;
      padding:2px 6px;
      border-radius:5px;
      pointer-events:none;
      display:none;
      z-index:10;
    }
    /* When today is active push badge to top-left corner of input */
    .date-wrap.is-today .today-badge{display:block}
    .date-wrap.is-today input[type="date"].ctrl{
      border-color:var(--accent);
      box-shadow:0 0 0 2px var(--accent-alpha);
    }

    /* "Go to today" button */
    .today-btn{
      height:40px;padding:0 11px;
      background:var(--surface-2);
      border:1px solid var(--border-med);
      border-radius:var(--r-sm);
      font-family:var(--font);font-size:13px;font-weight:600;
      color:var(--text-2);cursor:pointer;
      transition:all .18s;
      white-space:nowrap;
    }
    .today-btn:hover{border-color:var(--accent);color:var(--accent)}

    .dash-btn{
      display:flex;align-items:center;gap:8px;
      background:var(--surface-2);
      border:1px solid var(--border-med);
      color:var(--text-1);
      padding:0 13px;
      height:40px;
      border-radius:var(--r-sm);
      font-weight:600;font-size:14px;
      cursor:pointer;
      transition:all .2s;
    }
    .dash-btn.active{
      background:var(--accent);color:#fff;border-color:var(--accent);
    }

    .sel-wrap{position:relative}
    .sel-wrap select.ctrl{padding-left:28px}
    .sel-arrow{
      position:absolute;left:8px;top:50%;transform:translateY(-50%);
      pointer-events:none;color:var(--text-3);display:flex;
    }

    .theme-btn{
      width:40px;height:40px;
      border-radius:var(--r-sm);
      border:1px solid var(--border-med);
      background:var(--surface-2);
      color:var(--text-2);
      display:flex;align-items:center;justify-content:center;
      cursor:pointer;flex-shrink:0;
      transition:background .18s,color .18s;
    }
    .theme-btn:hover{background:var(--surface);color:var(--text-1)}

    /* ── STATS ── */
    .stats{
      display:flex;gap:10px;padding:16px 22px;
      flex-wrap:wrap;
    }

    @media(max-width:640px){
      .stats{padding:12px 14px;gap:8px}
    }

    .stat{
      flex:1;min-width:130px;
      display:flex;align-items:center;gap:14px;
      padding:14px 16px;
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:var(--r-md);
      box-shadow:var(--shadow-sm);
    }

    @media(max-width:400px){
      .stat{padding:12px 12px;gap:10px}
    }

    .stat-ico{
      width:44px;height:44px;
      border-radius:var(--r-sm);
      display:flex;align-items:center;justify-content:center;
      flex-shrink:0;
    }
    .stat-ico svg{width:19px;height:19px}
    .stat-ico.g{background:var(--green-badge);color:var(--green-text)}
    .stat-ico.r{background:var(--red-badge);color:var(--red-text)}
    .stat-ico.b{background:rgba(59,130,246,0.1);color:#3b82f6}

    .stat-num{font-size:28px;font-weight:700;line-height:1}
    .stat-num.g{color:var(--green-text)}
    .stat-num.r{color:var(--red-text)}
    .stat-lbl{font-size:13px;font-weight:500;color:var(--text-2);margin-top:4px}

    .pct{
      margin-right:auto;
      font-size:12px;font-weight:600;
      padding:3px 10px;border-radius:20px;
    }
    .pct.g{background:var(--green-badge);color:var(--green-text)}
    .pct.r{background:var(--red-badge);color:var(--red-text)}

    /* ══════════════════════════════════════
       TOOLBAR + QUICK-ACTION BUTTONS
       ══════════════════════════════════════ */
    .toolbar{
      display:flex;align-items:center;
      flex-wrap:wrap;
      gap:9px;
      padding:0 22px 14px;
    }

    @media(max-width:640px){
      .toolbar{padding:0 14px 12px}
    }

    .srch-wrap{flex:1;min-width:160px;position:relative}
    .srch-ico{
      position:absolute;right:12px;top:50%;transform:translateY(-50%);
      color:var(--text-3);pointer-events:none;display:flex;
    }
    .srch{
      width:100%;height:42px;
      background:var(--surface);
      border:1px solid var(--border-med);
      border-radius:var(--r-sm);
      font-family:var(--font);font-size:15px;
      color:var(--text-1);padding:0 40px 0 12px;outline:none;
      transition:border-color .18s,box-shadow .18s;
    }
    .srch::placeholder{color:var(--text-3)}
    .srch:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-alpha)}

    /* Quick-action buttons: تحديد الكل / إلغاء تحديد الكل */
    .qa-wrap{display:flex;gap:7px;flex-shrink:0}

    .qa-btn{
      height:42px;padding:0 13px;
      border-radius:var(--r-sm);
      border:1px solid;
      font-family:var(--font);font-size:13px;font-weight:600;
      cursor:pointer;
      display:flex;align-items:center;gap:6px;
      transition:opacity .15s,transform .12s;
      white-space:nowrap;
    }
    .qa-btn:active{transform:scale(.97)}
    .qa-btn.qa-g{
      background:var(--green-bg);
      border-color:var(--green-border);
      color:var(--green-text);
    }
    .qa-btn.qa-r{
      background:var(--red-bg);
      border-color:var(--red-border);
      color:var(--red-text);
    }
    .qa-btn svg{width:14px;height:14px}

    @media(max-width:520px){
      /* Show only icons on very small screens */
      .qa-btn .qa-lbl{display:none}
      .qa-btn{padding:0 11px;width:42px;justify-content:center}
    }

    /* tabs */
    .tabs{
      display:none;
      background:var(--surface-2);
      border:1px solid var(--border-med);
      border-radius:var(--r-sm);
      padding:4px;gap:4px;flex-shrink:0;
    }
    @media(max-width:767px){.tabs{display:flex}}

    .tab{
      height:34px;padding:0 13px;
      border-radius:6px;border:none;
      background:transparent;
      font-family:var(--font);font-size:14px;font-weight:600;
      color:var(--text-2);cursor:pointer;white-space:nowrap;
      transition:background .14s,color .14s;
    }
    .tab.ag{background:var(--green-badge);color:var(--green-text)}
    .tab.ar{background:var(--red-badge);color:var(--red-text)}

    /* ══════════════════════════════════════
       DASHBOARD LAYOUT
       ══════════════════════════════════════ */
    #dashboardUI{
      padding:0 22px 40px;
      animation:fadeIn .3s ease-out;
    }

    @media(max-width:640px){#dashboardUI{padding:0 14px 40px}}

    @keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}

    /* Dashboard meta bar: date range + overall rate */
    .dash-meta{
      display:flex;align-items:center;flex-wrap:wrap;gap:10px;
      margin-bottom:18px;
      padding:12px 16px;
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:var(--r-md);
      box-shadow:var(--shadow-sm);
    }
    .dash-meta-item{
      display:flex;align-items:center;gap:7px;
      font-size:13px;font-weight:500;color:var(--text-2);
    }
    .dash-meta-item svg{width:15px;height:15px;color:var(--accent);flex-shrink:0}
    .dash-meta-val{font-weight:700;color:var(--text-1)}
    .dash-meta-divider{width:1px;height:20px;background:var(--border-med);flex-shrink:0}
    @media(max-width:480px){.dash-meta-divider{display:none}}

    .dash-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(min(100%, 380px), 1fr));
      gap:18px;
    }

    .dash-card{
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:var(--r-lg);
      padding:22px;
      box-shadow:var(--shadow-sm);
    }
    .dash-card-title{
      font-size:15px;font-weight:700;
      margin-bottom:18px;
      display:flex;align-items:center;gap:9px;
      color:var(--text-1);
    }
    .dash-card-title svg{width:17px;color:var(--accent);flex-shrink:0}

    .chart-container{
      position:relative;
      height:240px;
      width:100%;
    }

    @media(max-width:400px){
      .chart-container{height:200px}
    }

    /* No-data placeholder */
    .no-data-placeholder{
      display:flex;flex-direction:column;align-items:center;justify-content:center;
      height:200px;gap:10px;color:var(--text-3);
    }
    .no-data-placeholder svg{width:40px;height:40px;opacity:.4}
    .no-data-placeholder p{font-size:14px;font-weight:500}

    .top-list{list-style:none}
    .top-item{
      display:flex;align-items:center;
      padding:11px 0;
      border-bottom:1px solid var(--border);
    }
    .top-item:last-child{border-bottom:none}
    .top-rank{
      width:26px;height:26px;
      background:var(--surface-2);
      border-radius:50%;
      display:flex;align-items:center;justify-content:center;
      font-size:11px;font-weight:700;color:var(--text-2);
      margin-left:11px;flex-shrink:0;
    }
    .top-name{flex:1;font-size:14px;font-weight:600;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .top-val{font-size:12px;font-weight:700;color:var(--red);background:var(--red-badge);padding:2px 8px;border-radius:6px;white-space:nowrap}

    /* ── COLUMNS ── */
    .cols{display:flex;gap:14px;padding:0 22px}
    @media(max-width:767px){.cols{padding:0 14px}}

    .col{flex:1;min-width:0}

    .col-hd{
      display:flex;align-items:center;justify-content:space-between;
      margin-bottom:12px;padding:0 2px;
    }
    .col-title{
      display:flex;align-items:center;gap:7px;
      font-size:12px;font-weight:600;
      color:var(--text-2);
      text-transform:uppercase;letter-spacing:.06em;
    }
    .dot{width:7px;height:7px;border-radius:50%}
    .dot.g{background:var(--green-text)}
    .dot.r{background:var(--red-text)}

    .col-right{display:flex;align-items:center;gap:9px}
    .col-n{font-size:21px;font-weight:700}
    .col-n.g{color:var(--green-text)}
    .col-n.r{color:var(--red-text)}

    .rst-btn{
      height:30px;padding:0 11px;
      border-radius:7px;
      border:1px solid var(--border-med);
      background:var(--surface);
      font-family:var(--font);font-size:12px;font-weight:600;
      color:var(--text-2);cursor:pointer;
      transition:border-color .14s,color .14s;
    }
    .rst-btn:hover{border-color:var(--accent);color:var(--accent)}

    /* ── STUDENT CARDS ── */
    .s-list{display:flex;flex-direction:column;gap:8px}

    .s-card{
      display:flex;align-items:center;gap:13px;
      padding:13px 14px;
      background:var(--surface);
      border:1px solid var(--border);
      border-radius:var(--r-md);
      cursor:pointer;
      box-shadow:var(--shadow-sm);
      user-select:none;
      animation:fadeUp .17s ease-out both;
      transition:border-color .15s,background .15s,box-shadow .15s,transform .12s;
    }
    @keyframes fadeUp{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}

    .s-card:active{transform:scale(.98)}
    .s-card.hg:hover{border-color:var(--green-border);background:var(--green-bg)}
    .s-card.hr:hover{border-color:var(--red-border);background:var(--red-bg)}

    .av{
      width:42px;height:42px;border-radius:10px;
      display:flex;align-items:center;justify-content:center;
      font-size:14px;font-weight:700;flex-shrink:0;letter-spacing:.2px;
    }
    .av.g{background:var(--green-badge);color:var(--green-text)}
    .av.r{background:var(--red-badge);color:var(--red-text)}

    .card-body{flex:1;min-width:0}
    .card-name{
      font-size:15px;font-weight:600;color:var(--text-1);
      white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
    }
    .card-sec{font-size:12px;font-weight:500;color:var(--text-3);margin-top:2px}

    .card-act{
      width:32px;height:32px;border-radius:8px;
      display:flex;align-items:center;justify-content:center;flex-shrink:0;
      transition:transform .14s;
    }
    .card-act svg{width:14px;height:14px}
    .card-act.g{background:var(--green-badge);color:var(--green-text)}
    .card-act.r{background:var(--red-badge);color:var(--red-text)}

    .s-card:hover .card-act{transform:translateX(3px)}

    /* ── EMPTY ── */
    .empty{
      display:flex;flex-direction:column;align-items:center;
      padding:48px 20px;gap:9px;
    }
    .empty-ico{
      width:50px;height:50px;border-radius:50%;
      background:var(--surface-2);border:1px solid var(--border-med);
      display:flex;align-items:center;justify-content:center;margin-bottom:4px;
    }
    .empty-ico svg{width:22px;height:22px;color:var(--text-3)}
    .empty-t{font-size:15px;font-weight:600;color:var(--text-2)}
    .empty-s{font-size:13px;color:var(--text-3)}

    /* ── LOADING ── */
    #loading{
      display:flex;flex-direction:column;align-items:center;
      justify-content:center;min-height:280px;gap:16px;
    }
    .spin{
      width:32px;height:32px;
      border:2.5px solid var(--border-med);
      border-top-color:var(--accent);
      border-radius:50%;
      animation:rot .7s linear infinite;
    }
    @keyframes rot{to{transform:rotate(360deg)}}
    .load-t{font-size:14px;font-weight:500;color:var(--text-2)}

    /* ── SAVE BAR ── */
    .save-bar{
      position:fixed;bottom:0;left:0;right:0;
      padding:12px 22px 24px;
      background:linear-gradient(to top,var(--bg) 60%,transparent);
      pointer-events:none;z-index:200;
    }
    .save-inner{
      max-width:480px;margin:0 auto;
      pointer-events:all;
      transform:translateY(80px);opacity:0;
      transition:transform .3s cubic-bezier(.34,1.4,.64,1),opacity .22s;
    }
    .save-inner.vis{transform:none;opacity:1}

    .save-btn{
      display:flex;align-items:center;justify-content:center;gap:10px;
      width:100%;height:54px;
      background:var(--accent);color:#fff;
      border:none;border-radius:var(--r-lg);
      font-family:var(--font);font-size:15px;font-weight:700;
      cursor:pointer;
      box-shadow:0 6px 18px rgba(229,62,62,.36);
      transition:background .14s,box-shadow .14s,transform .12s;
    }
    .save-btn svg{width:18px;height:18px}
    .save-btn:hover{background:var(--accent-dark);box-shadow:0 8px 24px rgba(229,62,62,.44)}
    .save-btn:active{transform:scale(.98)}
    .save-btn:disabled{opacity:.72;cursor:not-allowed}

    #statusMsg{
      text-align:center;font-size:13px;font-weight:600;
      padding:8px 14px;border-radius:var(--r-sm);
      margin-top:8px;display:none;
    }
    #statusMsg.ok{background:var(--green-badge);color:var(--green-text)}
    #statusMsg.er{background:var(--red-badge);color:var(--red-text)}

    .dim{opacity:.38;pointer-events:none;transition:opacity .3s}
    .gone{display:none!important}
    @media(max-width:767px){.mob-hide{display:none}}

    /* ── RECORDING STATUS BANNER ── */
    .rec-banner{
      margin:0 22px 12px;
      padding:12px 15px;
      background:rgba(245,158,11,.08);
      border:1px solid rgba(245,158,11,.28);
      border-radius:var(--r-sm);
      display:flex;align-items:center;gap:10px;
      font-size:13px;font-weight:500;
      color:#92400e;
      animation:fadeIn .3s ease-out;
    }
    [data-theme="dark"] .rec-banner{
      background:rgba(245,158,11,.1);
      border-color:rgba(245,158,11,.22);
      color:#fbbf24;
    }
    .rec-banner svg{width:16px;height:16px;flex-shrink:0}
    @media(max-width:640px){.rec-banner{margin:0 14px 12px}}

    /* ══════════════════════════════════════
       ONBOARDING GUIDE MODAL
       ══════════════════════════════════════ */
    .guide-overlay{
      position:fixed;inset:0;z-index:999;
      background:rgba(0,0,0,.55);
      backdrop-filter:blur(4px);
      display:flex;align-items:center;justify-content:center;
      padding:16px;
      opacity:0;
      animation:guideIn .35s ease-out forwards;
    }
    @keyframes guideIn{to{opacity:1}}
    .guide-overlay.closing{animation:guideOut .25s ease-in forwards}
    @keyframes guideOut{to{opacity:0}}

    .guide-modal{
      background:var(--surface);
      border-radius:var(--r-lg);
      box-shadow:0 20px 60px rgba(0,0,0,.2);
      max-width:480px;width:100%;
      max-height:90vh;overflow-y:auto;
      padding:28px 28px 24px;
      position:relative;
      transform:translateY(20px);
      animation:modalUp .35s ease-out forwards;
    }
    @keyframes modalUp{to{transform:translateY(0)}}

    .guide-badge{
      display:inline-flex;align-items:center;gap:7px;
      background:var(--accent-alpha);
      color:var(--accent);
      font-size:11px;font-weight:700;letter-spacing:.07em;
      padding:4px 11px;border-radius:20px;
      margin-bottom:14px;
      text-transform:uppercase;
    }
    .guide-badge svg{width:11px;height:11px}

    .guide-title{
      font-size:20px;font-weight:700;
      color:var(--text-1);margin-bottom:6px;
    }
    .guide-sub{
      font-size:13px;color:var(--text-2);
      margin-bottom:22px;line-height:1.6;
    }

    .guide-steps{display:flex;flex-direction:column;gap:14px;margin-bottom:24px}

    .guide-step{
      display:flex;gap:14px;
      padding:14px 15px;
      background:var(--surface-2);
      border:1px solid var(--border);
      border-radius:var(--r-md);
      transition:border-color .18s;
    }
    .guide-step:hover{border-color:var(--accent)}

    .guide-step-num{
      width:32px;height:32px;
      background:var(--accent);
      color:#fff;
      border-radius:50%;
      display:flex;align-items:center;justify-content:center;
      font-size:13px;font-weight:700;
      flex-shrink:0;margin-top:1px;
    }

    .guide-step-body{}
    .guide-step-title{
      font-size:14px;font-weight:700;
      color:var(--text-1);margin-bottom:4px;
    }
    .guide-step-desc{
      font-size:13px;color:var(--text-2);
      line-height:1.55;
    }
    .guide-step-desc b{color:var(--text-1);font-weight:600}

    .guide-tip{
      display:flex;gap:10px;align-items:flex-start;
      padding:12px 14px;
      background:rgba(59,130,246,.07);
      border:1px solid rgba(59,130,246,.18);
      border-radius:var(--r-sm);
      margin-bottom:22px;
    }
    .guide-tip svg{width:15px;height:15px;color:#3b82f6;flex-shrink:0;margin-top:1px}
    .guide-tip p{font-size:12px;color:#3b82f6;font-weight:500;line-height:1.55}

    .guide-close-btn{
      width:100%;height:48px;
      background:var(--accent);color:#fff;
      border:none;border-radius:var(--r-md);
      font-family:var(--font);font-size:15px;font-weight:700;
      cursor:pointer;
      box-shadow:0 4px 14px rgba(229,62,62,.3);
      transition:background .14s,box-shadow .14s,transform .12s;
      display:flex;align-items:center;justify-content:center;gap:8px;
    }
    .guide-close-btn:hover{background:var(--accent-dark)}
    .guide-close-btn:active{transform:scale(.98)}
    .guide-close-btn svg{width:16px;height:16px}

    /* Help button in header */
    .help-btn{
      width:40px;height:40px;
      border-radius:var(--r-sm);
      border:1px solid var(--border-med);
      background:var(--surface-2);
      color:var(--text-2);
      display:flex;align-items:center;justify-content:center;
      cursor:pointer;flex-shrink:0;
      font-size:16px;font-weight:700;
      transition:background .18s,color .18s,border-color .18s;
    }
    .help-btn:hover{background:var(--accent-alpha);border-color:var(--accent);color:var(--accent)}

    /* ══════════════════════════════════════
       UNDO BUTTON
       ══════════════════════════════════════ */
    .undo-btn{
      height:42px;padding:0 13px;
      border-radius:var(--r-sm);
      border:1px solid var(--border-med);
      background:var(--surface);
      color:var(--text-2);
      font-family:var(--font);font-size:13px;font-weight:600;
      cursor:pointer;
      display:flex;align-items:center;gap:6px;
      transition:all .18s;
      white-space:nowrap;
      animation:undoPop .25s cubic-bezier(.34,1.4,.64,1);
    }
    @keyframes undoPop{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}
    .undo-btn:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-alpha)}
    .undo-btn:active{transform:scale(.96)}
    .undo-btn svg{width:14px;height:14px}
    @media(max-width:520px){
      .undo-btn .undo-lbl{display:none}
      .undo-btn{padding:0 11px;width:42px;justify-content:center}
    }
  </style>
</head>
