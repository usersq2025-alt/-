<script>
  /* ════════════════════════════════════
     STATE
     ════════════════════════════════════ */
  let all=[], present=[], absent=[], origMap={}, activeTab='present', viewMode='attendance';
  let charts = {};

  /* ════════════════════════════════════
     THEME
     ════════════════════════════════════ */
  function applyTheme(dark){
    document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
    document.getElementById('ico-moon').style.display = dark ? 'none' : '';
    document.getElementById('ico-sun').style.display  = dark ? '' : 'none';
    if(charts.trend) updateChartsTheme();
  }
  function toggleTheme(){
    const d = document.documentElement.getAttribute('data-theme') === 'dark';
    localStorage.setItem('theme', d ? 'light' : 'dark');
    applyTheme(!d);
  }
  (()=>{
    const s = localStorage.getItem('theme');
    applyTheme(s ? s==='dark' : window.matchMedia('(prefers-color-scheme:dark)').matches);
  })();

  /* ════════════════════════════════════
     DATE HELPERS – smart "today" detection
     ════════════════════════════════════ */
  function getTodayStr(){
    // Use local date string (YYYY-MM-DD) to match input[type=date] value
    const d = new Date();
    const y = d.getFullYear();
    const m = String(d.getMonth()+1).padStart(2,'0');
    const day = String(d.getDate()).padStart(2,'0');
    return `${y}-${m}-${day}`;
  }

  function updateTodayIndicator(){
    const today  = getTodayStr();
    const picked = document.getElementById('datePicker').value;
    const wrap   = document.getElementById('dateWrap');
    if(picked === today){
      wrap.classList.add('is-today');
    } else {
      wrap.classList.remove('is-today');
    }
  }

  function goToToday(){
    document.getElementById('datePicker').value = getTodayStr();
    handleDateChange();
  }

  /* ════════════════════════════════════
     INIT
     ════════════════════════════════════ */
  window.onload = () => {
    const today = getTodayStr();
    document.getElementById('datePicker').value = today;
    updateTodayIndicator();

    google.script.run
      .withSuccessHandler(data => {
        all = data.students;
        document.getElementById('stat-total').textContent = all.length;
        origMap = data.initialAttendance || {};
        populateSections(data.sections);
        applyMap(origMap);
        // ← إظهار البانر إذا اليوم لم يُسجَّل بعد
        showRecordingBanner(!data.isTodayRecorded);
        document.getElementById('loading').classList.add('gone');
        document.getElementById('attendanceUI').classList.remove('gone');
      })
      .withFailureHandler(e => showMsg(e.message, false))
      .getInitialData();
  };

  function populateSections(secs){
    const sel = document.getElementById('sectionFilter');
    secs.forEach(s => {
      if(!s) return;
      const o = document.createElement('option');
      o.value = s; o.textContent = 'شعبة ' + s;
      sel.appendChild(o);
    });
  }

  function applyMap(map){
    present = []; absent = [];
    all.forEach(s => (map[s.id] === false ? absent : present).push(s));
    filterAndRender();
  }

  function handleDateChange(){
    updateTodayIndicator();
    if(viewMode === 'dashboard'){
      loadDashboard();
    } else {
      loadAttendanceForDate();
    }
  }

  function loadAttendanceForDate(){
    const d = document.getElementById('datePicker').value;
    document.getElementById('attendanceUI').classList.add('dim');
    google.script.run
      .withSuccessHandler(result => {
        // result = { attendance: {…}, isRecorded: bool }
        origMap = result.attendance;
        applyMap(result.attendance);
        showRecordingBanner(!result.isRecorded); // ← بانر تحذيري للأيام غير المسجَّلة
        document.getElementById('attendanceUI').classList.remove('dim');
      })
      .getAttendanceForDate(d);
  }

  /* إظهار/إخفاء بانر "لم يُسجَّل هذا اليوم بعد" */
  function showRecordingBanner(show){
    document.getElementById('recBanner').classList.toggle('gone', !show);
  }

  /* ════════════════════════════════════
     QUICK-ACTION: تحديد الكل / إلغاء تحديد الكل
     ════════════════════════════════════ */
  function setAllPresent(){
    // تصفير – جميع الطلاب حاضرون
    const sec = document.getElementById('sectionFilter').value;
    if(sec === 'ALL'){
      present = [...all]; absent = [];
    } else {
      // only affect current section filter
      const moved = absent.filter(s => s.section === sec);
      moved.forEach(s => {
        absent.splice(absent.indexOf(s), 1);
        present.unshift(s);
      });
    }
    filterAndRender();
  }

  function setAllAbsent(){
    // جميع الطلاب غائبون (مع مراعاة الفلتر)
    const sec = document.getElementById('sectionFilter').value;
    if(sec === 'ALL'){
      absent = [...all]; present = [];
    } else {
      const moved = present.filter(s => s.section === sec);
      moved.forEach(s => {
        present.splice(present.indexOf(s), 1);
        absent.unshift(s);
      });
    }
    filterAndRender();
  }

  /* ════════════════════════════════════
     DASHBOARD – يستدعي الـ backend الحقيقي
     ════════════════════════════════════ */
  function toggleDashboard(){
    const btn = document.getElementById('toggleDashBtn');
    if(viewMode === 'attendance'){
      viewMode = 'dashboard';
      btn.classList.add('active');
      btn.innerHTML = `<svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg><span class="mob-hide">تسجيل الحضور</span>`;
      document.getElementById('attendanceUI').classList.add('gone');
      document.getElementById('secFilterWrap').classList.add('gone');
      document.getElementById('dashboardUI').classList.remove('gone');
      document.getElementById('saveInner').classList.remove('vis');
      loadDashboard();
    } else {
      viewMode = 'attendance';
      btn.classList.remove('active');
      btn.innerHTML = `<svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M3 3v18h18M7 16l4-4 4 4 5-8"/></svg><span class="mob-hide">لوحة التحكم</span>`;
      document.getElementById('dashboardUI').classList.add('gone');
      document.getElementById('secFilterWrap').classList.remove('gone');
      document.getElementById('attendanceUI').classList.remove('gone');
      filterAndRender();
    }
  }

  function loadDashboard(){
    const dash = document.getElementById('dashboardUI');
    dash.classList.add('dim');

    // ── استدعاء الدالة الحقيقية من الـ backend ──
    google.script.run
      .withSuccessHandler(data => {
        renderDashboardMeta(data.meta);
        if(data.meta && data.meta.noData){
          showNoDashboardData();
        } else {
          renderCharts(data);
        }
        dash.classList.remove('dim');
      })
      .withFailureHandler(e => {
        showMsg('خطأ في تحميل لوحة التحكم: ' + e.message, false);
        dash.classList.remove('dim');
      })
      .getDashboardData();
  }

  /* ── تحديث شريط المعلومات في الداشبورد ── */
  function renderDashboardMeta(meta){
    if(!meta) return;
    document.getElementById('metaRange').textContent =
      meta.noData ? 'لا توجد بيانات بعد' : (meta.startDate + ' → ' + meta.endDate);
    document.getElementById('metaDays').textContent =
      meta.activeDays > 0 ? meta.activeDays + ' يوم' : '—';
    document.getElementById('metaRate').textContent =
      meta.overallRate > 0 ? meta.overallRate + '%' : '—';
  }

  function showNoDashboardData(){
    ['trendContainer','sectionContainer','weeklyContainer'].forEach(id => {
      document.getElementById(id).innerHTML = `
        <div class="no-data-placeholder">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p>لا توجد بيانات بعد 15 أبريل</p>
        </div>`;
    });
    document.getElementById('topAbsentList').innerHTML = `
      <li style="padding:20px;text-align:center;color:var(--text-3);font-size:14px">لا توجد سجلات غياب بعد</li>`;
  }

  /* ════════════════════════════════════
     CHART RENDERING
     ════════════════════════════════════ */
  function renderCharts(data){
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const textColor = isDark ? '#e6edf3' : '#111827';
    const gridColor = isDark ? 'rgba(255,255,255,0.05)' : 'rgba(0,0,0,0.05)';

    // 1. Trend Chart
    const trendContainer = document.getElementById('trendContainer');
    trendContainer.innerHTML = '<canvas id="trendChart"></canvas>';
    if(charts.trend) charts.trend.destroy();
    if(data.trend.labels.length === 0){
      trendContainer.innerHTML = `<div class="no-data-placeholder"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><p>لا توجد بيانات للرسم</p></div>`;
    } else {
      charts.trend = new Chart(document.getElementById('trendChart'), {
        type: 'line',
        data: {
          labels: data.trend.labels,
          datasets: [{
            label: 'نسبة الحضور %',
            data: data.trend.values,
            borderColor: '#e53e3e',
            backgroundColor: 'rgba(229,62,62,0.1)',
            fill: true, tension: 0.4, pointRadius: 4
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            y: { min: 0, max: 100, ticks: { color: textColor }, grid: { color: gridColor } },
            x: { ticks: { color: textColor }, grid: { display: false } }
          }
        }
      });
    }

    // 2. Section Chart
    const sectionContainer = document.getElementById('sectionContainer');
    sectionContainer.innerHTML = '<canvas id="sectionChart"></canvas>';
    if(charts.section) charts.section.destroy();
    if(data.sections.length === 0){
      sectionContainer.innerHTML = `<div class="no-data-placeholder"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><p>لا توجد بيانات للشعب</p></div>`;
    } else {
      charts.section = new Chart(document.getElementById('sectionChart'), {
        type: 'bar',
        data: {
          labels: data.sections.map(s => s.name),
          datasets: [{
            data: data.sections.map(s => s.rate),
            backgroundColor: data.sections.map(s => s.rate > 85 ? '#16a34a' : '#e53e3e'),
            borderRadius: 6
          }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            y: { min: 0, max: 100, ticks: { color: textColor }, grid: { color: gridColor } },
            x: { ticks: { color: textColor }, grid: { display: false } }
          }
        }
      });
    }

    // 3. Weekly Distribution
    const weeklyContainer = document.getElementById('weeklyContainer');
    weeklyContainer.innerHTML = '<canvas id="weeklyChart"></canvas>';
    if(charts.weekly) charts.weekly.destroy();
    charts.weekly = new Chart(document.getElementById('weeklyChart'), {
      type: 'radar',
      data: {
        labels: ['الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس'],
        datasets: [{
          label: 'متوسط الحضور',
          data: data.weekly,
          backgroundColor: 'rgba(59,130,246,0.2)',
          borderColor: '#3b82f6',
          pointBackgroundColor: '#3b82f6'
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          r: {
            angleLines: { color: gridColor },
            grid: { color: gridColor },
            pointLabels: { color: textColor, font: { family: 'IBM Plex Sans Arabic', size: 12 } },
            ticks: { display: false },
            min: 0, max: 100
          }
        }
      }
    });

    // 4. Top Absent List
    const listEl = document.getElementById('topAbsentList');
    if(!data.topAbsent || data.topAbsent.length === 0){
      listEl.innerHTML = `<li style="padding:20px;text-align:center;color:var(--text-3);font-size:14px">🎉 لا يوجد غياب متكرر</li>`;
    } else {
      listEl.innerHTML = data.topAbsent.map((s, i) => `
        <li class="top-item">
          <span class="top-rank">${i+1}</span>
          <span class="top-name">${s.name}</span>
          <span class="top-val">${s.count} أيام</span>
        </li>
      `).join('');
    }
  }

  function updateChartsTheme(){
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const textColor = isDark ? '#e6edf3' : '#111827';
    const gridColor = isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.05)';
    [charts.trend, charts.section].forEach(chart => {
      if(!chart) return;
      chart.options.scales.x.ticks.color = textColor;
      chart.options.scales.y.ticks.color = textColor;
      chart.options.scales.y.grid.color  = gridColor;
      chart.update();
    });
    if(charts.weekly){
      charts.weekly.options.scales.r.pointLabels.color  = textColor;
      charts.weekly.options.scales.r.angleLines.color   = gridColor;
      charts.weekly.options.scales.r.grid.color         = gridColor;
      charts.weekly.update();
    }
  }

  /* ════════════════════════════════════
     LIST UI
     ════════════════════════════════════ */
  function switchTab(tab){
    activeTab = tab;
    document.getElementById('tab-p').className = 'tab '+(tab==='present'?'ag':'');
    document.getElementById('tab-a').className = 'tab '+(tab==='absent'?'ar':'');
    filterAndRender();
  }

  function filterAndRender(){
    if(viewMode === 'dashboard') return;

    const sec = document.getElementById('sectionFilter').value;
    const q   = (document.getElementById('srch').value || '').trim();
    const mob = window.innerWidth < 768;

    const match = s =>
      (sec==='ALL' || s.section===sec) && (!q || s.name.includes(q));

    const fP = present.filter(match);
    const fA = absent.filter(match);
    const tot = fP.length + fA.length || 1;

    const set = (id, v) => { const e=document.getElementById(id); if(e) e.textContent=v; };
    set('pc-n', fP.length); set('ac-n', fA.length);
    set('tp-n', fP.length); set('ta-n', fA.length);
    set('stat-p', fP.length); set('stat-a', fA.length);
    set('pct-p', Math.round(fP.length/tot*100)+'%');
    set('pct-a', Math.round(fA.length/tot*100)+'%');

    const cp = document.getElementById('col-p');
    const ca = document.getElementById('col-a');
    if(mob){
      cp.classList.toggle('gone', activeTab!=='present');
      ca.classList.toggle('gone', activeTab!=='absent');
    } else {
      cp.classList.remove('gone');
      ca.classList.remove('gone');
    }

    render('presentList', fP, 'g', 'present');
    render('absentList',  fA, 'r', 'absent');
    checkChanges();
  }

  function ini(name){
    const p = name.trim().split(' ');
    return p.length>=2 ? p[0][0]+p[1][0] : p[0].substring(0,2);
  }

  function render(id, list, color, from){
    const el = document.getElementById(id);
    if(!list.length){
      el.innerHTML = `<div class="empty">
        <div class="empty-ico"><svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="width:18px;height:18px"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
        <div class="empty-t">لا توجد نتائج</div>
        <div class="empty-s">عدّل الفلتر أو البحث</div>
      </div>`;
      return;
    }
    const arr = color==='g'
      ? `<svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`
      : `<svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>`;

    el.innerHTML = list.map((s, i) => `
      <div class="s-card h${color}" style="animation-delay:${Math.min(i*.022,.28)}s"
           onclick="move('${s.id}','${from}')">
        <div class="av ${color}">${ini(s.name)}</div>
        <div class="card-body">
          <div class="card-name">${s.name}</div>
          <div class="card-sec">شعبة ${s.section}</div>
        </div>
        <div class="card-act ${color}">${arr}</div>
      </div>`).join('');
  }

  function move(id, from){
    if(from==='present'){
      const i = present.findIndex(s=>s.id===id);
      if(i!==-1) absent.unshift(present.splice(i,1)[0]);
    } else {
      const i = absent.findIndex(s=>s.id===id);
      if(i!==-1) present.unshift(absent.splice(i,1)[0]);
    }
    filterAndRender();
  }

  function checkChanges(){
    if(viewMode==='dashboard') return;
    let ch = false;
    absent.forEach(s  => { if(origMap[s.id] !== false) ch=true; });
    present.forEach(s => { if(origMap[s.id] === false) ch=true; });
    document.getElementById('saveInner').classList.toggle('vis', ch);
  }

  /* ════════════════════════════════════
     SAVE
     ════════════════════════════════════ */
  function submitAttendance(){
    const btn  = document.getElementById('saveBtn');
    const date = document.getElementById('datePicker').value;
    btn.disabled = true;
    btn.innerHTML = `<div class="spin" style="width:18px;height:18px;border-width:2px;border-color:rgba(255,255,255,.2);border-top-color:#fff"></div>`;

    const attendance = {};
    all.forEach(s    => { attendance[s.id] = true;  });
    absent.forEach(s => { attendance[s.id] = false; });

    const reset = () => {
      btn.disabled = false;
      btn.innerHTML = `<svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> حفظ ومزامنة السجل`;
    };

    google.script.run
      .withSuccessHandler(msg => {
        origMap = {...attendance};
        checkChanges();
        showMsg(msg || 'تم الحفظ بنجاح ✓', true);
        reset();
      })
      .withFailureHandler(e => { showMsg(e.message, false); reset(); })
      .saveAttendance({ date, attendance });
  }

  function showMsg(msg, ok){
    const el = document.getElementById('statusMsg');
    el.textContent = msg; el.className = ok ? 'ok' : 'er';
    el.style.display = 'block';
    setTimeout(() => { el.style.display='none'; }, 4000);
  }

  window.addEventListener('resize', filterAndRender);

  /* ════════════════════════════════════
     ONBOARDING GUIDE
     ════════════════════════════════════ */
  function openGuide(){
    const el = document.getElementById('guideOverlay');
    el.classList.remove('gone');
    el.classList.remove('closing');
    document.body.style.overflow = 'hidden';
  }

  function closeGuide(){
    const el = document.getElementById('guideOverlay');
    el.classList.add('closing');
    setTimeout(()=>{
      el.classList.add('gone');
      el.classList.remove('closing');
      document.body.style.overflow = '';
    }, 250);
    localStorage.setItem('jasoor_guide_seen', '1');
  }

  function handleOverlayClick(e){
    // إغلاق عند الضغط خارج المودال
    if(e.target === document.getElementById('guideOverlay')) closeGuide();
  }

  // إغلاق بـ Escape
  document.addEventListener('keydown', e=>{
    if(e.key === 'Escape' && !document.getElementById('guideOverlay').classList.contains('gone')) closeGuide();
  });

  // عرض الدليل لأول مرة فقط
  window.addEventListener('load', ()=>{
    if(!localStorage.getItem('jasoor_guide_seen')){
      // تأخير بسيط حتى يتحمّل التطبيق أولاً
      setTimeout(openGuide, 900);
    }
  }, {once: false});


  /* ════════════════════════════════════
     UNDO SYSTEM – التراجع عن آخر عملية
     ════════════════════════════════════ */
  let undoStack = [];

  function pushUndoSnapshot(){
    // نسخ الحالة الحالية قبل أي تعديل
    undoStack.push({
      present: [...present],
      absent:  [...absent]
    });
    document.getElementById('undoBtn').classList.remove('gone');
  }

  function undoLast(){
    if(!undoStack.length) return;
    const snap = undoStack.pop();
    present = snap.present;
    absent  = snap.absent;
    filterAndRender();
    if(!undoStack.length){
      document.getElementById('undoBtn').classList.add('gone');
    }
    showMsg('تم التراجع عن آخر عملية ↩', true);
  }

  // ── تغليف الدوال المؤثرة على الحالة بدون تعديل الكود الأصلي ──
  (function(){
    const _move = window.move || move;
    window.move = function(id, from){
      pushUndoSnapshot();
      _move(id, from);
    };

    const _setAllPresent = window.setAllPresent || setAllPresent;
    window.setAllPresent = function(){
      pushUndoSnapshot();
      _setAllPresent();
    };

    const _setAllAbsent = window.setAllAbsent || setAllAbsent;
    window.setAllAbsent = function(){
      pushUndoSnapshot();
      _setAllAbsent();
    };

    const _submitAttendance = window.submitAttendance || submitAttendance;
    window.submitAttendance = function(){
      // بعد الحفظ الناجح يُفرَّغ مكدس التراجع (البيانات محفوظة في السحابة)
      undoStack = [];
      document.getElementById('undoBtn').classList.add('gone');
      _submitAttendance();
    };
  })();
</script>
</body>
