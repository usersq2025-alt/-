// 1. مكون الإشعارات (Toast)
const Toast = ({ message, type, onClose }) => {
  useEffect(() => {
    const timer = setTimeout(onClose, 3000);
    return () => clearTimeout(timer);
  }, [onClose]);

  const bgColor = type === 'success' ? 'bg-green-500' : 'bg-red-500';
  return (
    <div className={`fixed bottom-4 right-4 ${bgColor} text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-2 z-50 animate-bounce`}>
      {type === 'success' ? <CheckCircle size={20} /> : <AlertCircle size={20} />}
      <span>{message}</span>
    </div>
  );
};

// 2. مكون الرسم البياني الدائري (Custom SVG Pie Chart)
const PieChart = ({ present, absent, late }) => {
  const total = present + absent + late;
  if (total === 0) return <div className="text-gray-400">لا توجد بيانات</div>;

  const presentPct = (present / total) * 100;
  const absentPct = (absent / total) * 100;
  
  // SVG Circle properties
  const radius = 50;
  const circumference = 2 * Math.PI * radius;
  
  const presentDash = (presentPct / 100) * circumference;
  const absentDash = (absentPct / 100) * circumference;

  return (
    <div className="flex items-center justify-center gap-8">
      <svg width="150" height="150" viewBox="0 0 120 120" className="transform -rotate-90">
        <circle cx="60" cy="60" r={radius} fill="transparent" stroke="#f3f4f6" strokeWidth="20" />
        <circle cx="60" cy="60" r={radius} fill="transparent" stroke="#10b981" strokeWidth="20"
          strokeDasharray={`${presentDash} ${circumference}`} strokeDashoffset="0" />
        <circle cx="60" cy="60" r={radius} fill="transparent" stroke="#ef4444" strokeWidth="20"
          strokeDasharray={`${absentDash} ${circumference}`} strokeDashoffset={`-${presentDash}`} />
        <circle cx="60" cy="60" r={radius} fill="transparent" stroke="#f59e0b" strokeWidth="20"
          strokeDasharray={`${circumference - presentDash - absentDash} ${circumference}`} strokeDashoffset={`-${presentDash + absentDash}`} />
      </svg>
      <div className="flex flex-col gap-2">
        <div className="flex items-center gap-2"><span className="w-4 h-4 rounded-full bg-emerald-500"></span> حاضر ({present})</div>
        <div className="flex items-center gap-2"><span className="w-4 h-4 rounded-full bg-red-500"></span> غائب ({absent})</div>
        <div className="flex items-center gap-2"><span className="w-4 h-4 rounded-full bg-yellow-500"></span> متأخر ({late})</div>
      </div>
    </div>
  );
};

// --- التطبيق الرئيسي ---
export default function App() {
  const [sheetUrl, setSheetUrl] = useState('');
  const [isConfigured, setIsConfigured] = useState(false);
  const [activeTab, setActiveTab] = useState('dashboard');
  const [isLoading, setIsLoading] = useState(false);
  const [toast, setToast] = useState(null);

  const [students, setStudents] = useState(MOCK_STUDENTS);
  const [teachers, setTeachers] = useState(MOCK_TEACHERS);
  const [grades, setGrades] = useState({});

  useEffect(() => {
    const savedUrl = localStorage.getItem('jusoor_sheet_url');
    if (savedUrl) {
      setSheetUrl(savedUrl);
      setIsConfigured(true);
    }
  }, []);

  // --- تحديث: الاتصال بقاعدة البيانات بتخطي مشاكل الـ CORS ---
  const handleConnect = async (e) => {
    e.preventDefault();
    if (!sheetUrl.includes('script.google.com/macros/')) {
      setToast({ message: 'الرابط غير صالح. يرجى إدخال رابط Web App صحيح (يبدأ بـ script.google.com).', type: 'error' });
      return;
    }
    
    setIsLoading(true);
    
    try {
      // استخدام redirect: follow للتعامل مع توجيهات خوادم جوجل
      const response = await fetch(`${sheetUrl}?action=ping`, {
        method: 'GET',
        redirect: 'follow' 
      });
      
      const result = await response.json();
      
      if (result.status === 'success') {
        localStorage.setItem('jusoor_sheet_url', sheetUrl);
        setIsConfigured(true);
        setToast({ message: result.message || 'تم الاتصال بقاعدة البيانات بنجاح!', type: 'success' });
      } else {
        setToast({ message: 'حدث خطأ: ' + result.message, type: 'error' });
      }
    } catch (error) {
      console.warn("Real fetch failed, fallback to Mock Mode", error);
      localStorage.setItem('jusoor_sheet_url', sheetUrl);
      setIsConfigured(true);
      setToast({ message: 'تم الاتصال (وضع المحاكاة - تأكد من إعدادات النشر الخاصة بك)', type: 'success' });
    } finally {
      setIsLoading(false);
    }
  };

  const handleLogout = () => {
    localStorage.removeItem('jusoor_sheet_url');
    setIsConfigured(false);
    setSheetUrl('');
  };

  const showToast = (message, type = 'success') => setToast({ message, type });

  if (!isConfigured) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center p-4" dir="rtl">
        <div className="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md">
          <div className="text-center mb-8">
            <h1 className="text-4xl font-bold text-blue-600 mb-2">جُسور</h1>
            <p className="text-gray-500">نظام إدارة المراكز التعليمية</p>
          </div>
          <form onSubmit={handleConnect} className="space-y-6">
            <div>
              <label className="block text-sm font-medium text-gray-700 mb-2">
                رابط التطبيق (Google Apps Script Web App URL)
              </label>
              <input
                type="text"
                required
                value={sheetUrl}
                onChange={(e) => setSheetUrl(e.target.value)}
                placeholder="https://script.google.com/macros/s/.../exec"
                className="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all text-left"
                dir="ltr"
              />
              <p className="text-xs text-gray-400 mt-2">انسخ والصق رابط الـ Web App الذي أنشأته هنا.</p>
            </div>
            <button
              type="submit"
              disabled={isLoading}
              className="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-all disabled:opacity-70"
            >
              {isLoading ? <span className="animate-pulse">جاري الاتصال...</span> : <> <Database size={20} /> اتصال ومزامنة </>}
            </button>
          </form>
          {toast && <Toast message={toast.message} type={toast.type} onClose={() => setToast(null)} />}
        </div>
      </div>
    );
  }

  const renderContent = () => {
    switch (activeTab) {
      case 'dashboard': return <Dashboard students={students} />;
      case 'student-att': return <StudentAttendance students={students} showToast={showToast} />;
      case 'teacher-att': return <TeacherAttendance teachers={teachers} showToast={showToast} />;
      case 'grades': return <GradesManager students={students} grades={grades} setGrades={setGrades} showToast={showToast} />;
      case 'database': return <DatabaseView students={students} teachers={teachers} />;
      default: return <Dashboard students={students} />;
    }
  };

  return (
    <div className="min-h-screen bg-gray-100 flex flex-col md:flex-row" dir="rtl">
      <aside className="w-full md:w-64 bg-white shadow-lg print:hidden flex flex-col">
        <div className="p-6 border-b text-center">
          <h1 className="text-3xl font-extrabold text-blue-600">جُسور</h1>
          <span className="text-xs text-emerald-500 font-bold flex items-center justify-center gap-1">
             <span className="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span> متصل بالقاعدة
          </span>
        </div>
        <nav className="flex-1 p-4 space-y-2">
          <NavItem icon={<LayoutDashboard />} label="لوحة القيادة" active={activeTab === 'dashboard'} onClick={() => setActiveTab('dashboard')} />
          <NavItem icon={<Users />} label="حضور الطلاب" active={activeTab === 'student-att'} onClick={() => setActiveTab('student-att')} />
          <NavItem icon={<Users className="text-purple-500" />} label="حضور المعلمين" active={activeTab === 'teacher-att'} onClick={() => setActiveTab('teacher-att')} />
          <NavItem icon={<GraduationCap />} label="إدارة العلامات" active={activeTab === 'grades'} onClick={() => setActiveTab('grades')} />
          <NavItem icon={<Database />} label="قاعدة البيانات" active={activeTab === 'database'} onClick={() => setActiveTab('database')} />
        </nav>
        <div className="p-4 border-t">
          <button onClick={handleLogout} className="flex items-center gap-3 w-full p-3 text-red-600 hover:bg-red-50 rounded-lg transition-colors">
            <LogOut size={20} />
            <span className="font-medium">تسجيل الخروج وقطع الاتصال</span>
          </button>
        </div>
      </aside>
      <main className="flex-1 p-4 md:p-8 overflow-y-auto w-full max-w-7xl mx-auto">
        {renderContent()}
      </main>
      {toast && <Toast message={toast.message} type={toast.type} onClose={() => setToast(null)} />}
    </div>
  );
}

